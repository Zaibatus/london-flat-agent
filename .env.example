# Path to your Google service account JSON key file.
# Alternatively, paste the raw JSON content here (must start with '{').
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Google Sheet name exactly as it appears in Drive
SPREADSHEET_NAME=London flat hunt

# Tab name within that sheet
SHEET_TAB=Flats

# Gemini model to use for extraction.
# Check https://ai.google.dev/gemini-api/docs/models for current model IDs.
GEMINI_MODEL=gemini-2.5-flash

# A scratch cell for the smoke test to write/read. Must NOT be in columns I–L (9–12).
# Default M1 is safe.
SMOKE_TEST_CELL=M1
